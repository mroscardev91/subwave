---
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = ui[lang].app.config;

// Lista mínima para Hito 2; el catálogo real (Whisper/NLLB) llega en Hitos 4 y 6.
const langs = [
  { code: "en", label: "English" },
  { code: "es", label: "Español" },
  { code: "fr", label: "Français" },
  { code: "de", label: "Deutsch" },
  { code: "pt", label: "Português" },
  { code: "it", label: "Italiano" },
];

const selectClass =
  "mt-2 w-full appearance-none rounded-card border border-on-deep-soft/25 bg-deep-soft px-4 py-3 text-on-deep transition focus-visible:outline-none focus-visible:border-aqua focus-visible:ring-2 focus-visible:ring-aqua";
---

<section data-stage="config" hidden aria-labelledby="config-h" class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
  <h2 id="config-h" data-stage-heading tabindex="-1" class="text-3xl text-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua sm:text-4xl">{c.title}</h2>
  <p class="mt-3 text-on-deep-soft">{c.lead}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    <div>
      <label for="cfg-source" class="font-mono text-xs uppercase tracking-wide text-on-deep-soft">{c.source}</label>
      <select id="cfg-source" class={selectClass}>
        <option value="auto">{c.autodetect}</option>
        {langs.map((l) => <option value={l.code}>{l.label}</option>)}
      </select>
    </div>
    <div>
      <label for="cfg-target" class="font-mono text-xs uppercase tracking-wide text-on-deep-soft">{c.target}</label>
      <select id="cfg-target" class={selectClass}>
        {langs.map((l) => <option value={l.code} selected={l.code === lang}>{l.label}</option>)}
      </select>
    </div>
  </div>

  <p class="mt-5 rounded-card border border-on-deep-soft/20 bg-deep-soft px-4 py-3 text-sm text-on-deep-soft">{c.note}</p>

  <div class="mt-10 flex items-center justify-between">
    <button type="button" data-action="back" class="rounded-pill border border-on-deep-soft/30 px-5 py-3 font-medium text-on-deep transition hover:border-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua">{ui[lang].app.back}</button>
    <button type="button" data-action="next" class="rounded-pill bg-aqua px-6 py-3 font-medium text-deep transition hover:bg-aqua-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua focus-visible:ring-offset-2 focus-visible:ring-offset-deep">{c.transcribe}</button>
  </div>
</section>
