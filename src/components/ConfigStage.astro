---
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";
import { languageOptions } from "@/scripts/languages";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = ui[lang].app.config;
const langs = languageOptions;

const selectClass =
  "mt-2 w-full appearance-none rounded-card border border-on-deep-soft/25 bg-deep-soft px-4 py-3 text-on-deep transition focus-visible:outline-none focus-visible:border-aqua focus-visible:ring-2 focus-visible:ring-aqua";
---

<section data-stage="config" hidden aria-labelledby="config-h" class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
  <h2 id="config-h" data-stage-heading tabindex="-1" class="text-3xl text-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua sm:text-4xl">{c.title}</h2>
  <p class="mt-3 text-on-deep-soft">{c.lead}</p>

  <div data-config="form">
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      <div>
        <label for="cfg-source" class="font-mono text-xs uppercase tracking-wide text-on-deep-soft">{c.source}</label>
        <select id="cfg-source" class={selectClass}>
          <option value="auto">{c.autodetect}</option>
          {langs.map((l) => <option value={l.code}>{l.label}</option>)}
        </select>
      </div>
      <div>
        <label for="cfg-target" class="font-mono text-xs uppercase tracking-wide text-on-deep-soft">{c.target}</label>
        <select id="cfg-target" class={selectClass}>
          <option value="">{c.sameAsAudio}</option>
          {langs.map((l) => <option value={l.code}>{l.label}</option>)}
        </select>
      </div>
    </div>

    <p class="mt-5 rounded-card border border-on-deep-soft/20 bg-deep-soft px-4 py-3 text-sm text-on-deep-soft">{c.note}</p>

    <!-- Aviso en dispositivos de poca RAM: la transcripción con IA puede no caber. -->
    <p data-config="device-warn" hidden class="mt-3 flex items-start gap-2 rounded-card border border-alert/35 bg-alert/10 px-4 py-3 text-sm text-on-deep">
      <svg viewBox="0 0 16 16" class="mt-px h-4 w-4 shrink-0 text-alert" aria-hidden="true"><path d="M8 1.5 15 14H1z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" /><path d="M8 6.5v3.2M8 11.6v.1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>
      {c.deviceWarn}
    </p>
  </div>

  <!-- Progreso de descarga del modelo + transcripción -->
  <div data-config="progress" hidden class="mt-8">
    <div class="flex items-center justify-between text-sm text-on-deep-soft">
      <span data-config="status" id="config-status" tabindex="-1" aria-live="polite" class="focus:outline-none"></span>
      <span data-config="pct" class="font-mono"></span>
    </div>
    <div data-config="bar-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-labelledby="config-status" class="mt-2 h-2 overflow-hidden rounded-pill bg-deep-soft">
      <div data-config="bar" class="h-full rounded-pill bg-aqua transition-[width] duration-200" style="width:0%"></div>
    </div>
    <p class="mt-3 font-mono text-xs text-on-deep-soft">{c.note}</p>
  </div>

  <p data-config="error" hidden role="alert" tabindex="-1" class="mt-8 flex items-center gap-2 rounded-card border border-alert/40 bg-alert/10 px-4 py-3 text-sm text-alert focus:outline-none">
    <svg viewBox="0 0 16 16" class="h-4 w-4 shrink-0" aria-hidden="true"><path d="M8 1.5 15 14H1z M8 6v4 M8 11.5v.5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round" /></svg>
    <span data-config="error-text"></span>
  </p>

  <div class="mt-10 flex items-center justify-between">
    <button type="button" data-action="back" class="rounded-pill border border-on-deep-soft/30 px-5 py-3 font-medium text-on-deep transition hover:border-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua disabled:cursor-not-allowed disabled:opacity-40">{ui[lang].app.back}</button>
    <button id="config-transcribe" type="button" class="rounded-pill bg-aqua px-6 py-3 font-medium text-deep transition hover:bg-aqua-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua focus-visible:ring-offset-2 focus-visible:ring-offset-deep disabled:cursor-not-allowed disabled:opacity-40">{c.transcribe}</button>
  </div>
</section>
