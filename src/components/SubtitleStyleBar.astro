---
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const e = ui[lang].app.editor;
const sb = e.styleBar;
const presets: { id: string; label: string }[] = [
  { id: "base", label: e.presets.base },
  { id: "clean", label: e.presets.clean },
  { id: "bold", label: e.presets.bold },
  { id: "pop", label: e.presets.pop },
  { id: "neon", label: e.presets.neon },
  { id: "classic", label: e.presets.classic },
  { id: "terminal", label: e.presets.terminal },
];

const field = "flex flex-col gap-1.5 text-xs font-mono uppercase tracking-wide text-on-deep-soft";
const select =
  "rounded-lg border border-on-deep-soft/25 bg-deep px-3 py-1.5 font-sans text-sm normal-case text-on-deep focus-visible:outline-none focus-visible:border-aqua focus-visible:ring-2 focus-visible:ring-aqua";
---

<div class="flex flex-wrap items-center gap-2">
  {presets.map((p) => (
    <button type="button" data-preset={p.id} aria-pressed="false" class="preset-chip">
      <span class="font-display text-lg leading-none" aria-hidden="true">Aa</span>
      <span class="text-[11px] leading-none">{p.label}</span>
    </button>
  ))}

  <button type="button" data-editor="customize-toggle" aria-expanded="false" aria-controls="subtitle-style-panel" class="ml-1 inline-flex items-center gap-1.5 rounded-pill border border-on-deep-soft/30 px-3 py-2 text-sm text-on-deep transition hover:border-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua">
    <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" aria-hidden="true"><path d="M6 2h4l.4 2 1.7 1 2-.7 2 3.4-1.6 1.3v2l1.6 1.3-2 3.4-2-.7-1.7 1L10 18H6l-.4-2-1.7-1-2 .7-2-3.4L1.5 11V9L-.1 7.7l2-3.4 2 .7 1.7-1z" fill="none" stroke="currentColor" stroke-width="1.1" transform="scale(0.8) translate(2 1)" /></svg>
    {e.customize}
  </button>
</div>

<!-- Controles finos (popover, abre hacia arriba; no empuja el layout) -->
<div data-editor="custom" id="subtitle-style-panel" hidden class="absolute bottom-[calc(100%-0.25rem)] left-6 right-6 z-30 rounded-card border border-on-deep-soft/15 bg-deep-soft p-4 shadow-soft">
  <div class="flex flex-wrap items-end gap-x-5 gap-y-4">
    <label class={field}>
      {sb.font}
      <select data-style="font" class={select}>
        <option value="sans">{sb.sans}</option>
        <option value="serif">{sb.serif}</option>
        <option value="mono">{sb.mono}</option>
      </select>
    </label>
    <label class={field}>
      {sb.size}
      <input type="range" data-style="size" min="0.7" max="1.6" step="0.05" value="1" class="accent-aqua" />
    </label>
    <label class={field}>
      {sb.color}
      <input type="color" data-style="color" class="h-9 w-12 cursor-pointer rounded-lg border border-on-deep-soft/25 bg-deep" />
    </label>
    <label class={field}>
      {sb.background}
      <input type="color" data-style="bg" class="h-9 w-12 cursor-pointer rounded-lg border border-on-deep-soft/25 bg-deep" />
    </label>
    <label class={field}>
      {sb.opacity}
      <input type="range" data-style="bgOpacity" min="0" max="100" step="5" class="accent-aqua" />
    </label>
    <label class="flex cursor-pointer items-center gap-2 pb-1.5 text-sm text-on-deep">
      <input type="checkbox" data-style="outline" class="h-4 w-4 accent-aqua" />
      {sb.outline}
    </label>
    <label class={field}>
      {sb.position}
      <select data-style="position" class={select}>
        <option value="top">{sb.top}</option>
        <option value="middle">{sb.middle}</option>
        <option value="bottom">{sb.bottom}</option>
      </select>
    </label>
  </div>
</div>

<style>
  .preset-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    width: 4.25rem;
    height: 3.5rem;
    border-radius: 12px;
    border: 1px solid color-mix(in oklab, var(--color-on-deep-soft) 25%, transparent);
    background: var(--color-deep-soft);
    color: var(--color-on-deep);
    transition: border-color 0.15s, background 0.15s;
  }
  .preset-chip:hover { border-color: var(--color-on-deep-soft); }
  .preset-chip:focus-visible { outline: 2px solid var(--color-aqua); outline-offset: 1px; }
  .preset-chip.is-active {
    border-color: var(--color-aqua);
    background: color-mix(in oklab, var(--color-aqua) 12%, var(--color-deep-soft));
  }
  .preset-chip.is-active .font-display { color: var(--color-aqua); }
</style>
