---
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const e = ui[lang].app.editor;
const sb = e.styleBar;
const presets: { id: string; label: string }[] = [
  { id: "base", label: e.presets.base },
  { id: "clean", label: e.presets.clean },
  { id: "bold", label: e.presets.bold },
  { id: "pop", label: e.presets.pop },
  { id: "neon", label: e.presets.neon },
  { id: "classic", label: e.presets.classic },
  { id: "terminal", label: e.presets.terminal },
];

const field = "flex flex-col gap-1.5 text-xs font-mono uppercase tracking-wide text-on-deep-soft";
const select =
  "rounded-lg border border-on-deep-soft/25 bg-deep px-3 py-1.5 font-sans text-sm normal-case text-on-deep focus-visible:outline-none focus-visible:border-aqua focus-visible:ring-2 focus-visible:ring-aqua";
---

<div class="flex flex-wrap items-center justify-between gap-2">
  <div class="flex flex-wrap items-center gap-2">
    {presets.map((p) => (
      <button type="button" data-preset={p.id} aria-pressed="false" class="preset-chip">
        <span class="font-display text-lg leading-none" aria-hidden="true">Aa</span>
        <span class="text-[11px] leading-none">{p.label}</span>
      </button>
    ))}
  </div>

  <div class="flex items-center gap-2">
    <button type="button" data-editor="animation-toggle" aria-pressed="false" class="ctl-pill">
      <span class="ctl-w" aria-hidden="true">W</span>
      {e.animation}
    </button>
    <button type="button" data-editor="customize-toggle" aria-expanded="false" aria-controls="subtitle-style-panel" class="ctl-pill">
      <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" aria-hidden="true"><path d="M2 4h7M11 4h3M2 8h3M7 8h7M2 12h9M13 12h1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="10" cy="4" r="1.6" fill="currentColor"/><circle cx="6" cy="8" r="1.6" fill="currentColor"/><circle cx="12" cy="12" r="1.6" fill="currentColor"/></svg>
      {e.customize}
    </button>
  </div>
</div>

<!-- Controles finos (panel inline; al abrir empuja la preview, no la tapa) -->
<div data-editor="custom" id="subtitle-style-panel" hidden class="mt-3 rounded-card border border-on-deep-soft/15 bg-deep-soft p-4">
  <div class="flex flex-wrap items-end gap-x-5 gap-y-4">
    <label class={field}>
      {sb.font}
      <select data-style="font" class={select}>
        <option value="sans">{sb.sans}</option>
        <option value="serif">{sb.serif}</option>
        <option value="mono">{sb.mono}</option>
      </select>
    </label>
    <label class={field}>
      {sb.size}
      <input type="range" data-style="size" min="0.7" max="1.6" step="0.05" value="1" class="accent-aqua" />
    </label>
    <label class={field}>
      {sb.color}
      <input type="color" data-style="color" class="h-9 w-12 cursor-pointer rounded-lg border border-on-deep-soft/25 bg-deep" />
    </label>
    <label class={field}>
      {sb.background}
      <input type="color" data-style="bg" class="h-9 w-12 cursor-pointer rounded-lg border border-on-deep-soft/25 bg-deep" />
    </label>
    <label class={field}>
      {sb.opacity}
      <input type="range" data-style="bgOpacity" min="0" max="100" step="5" class="accent-aqua" />
    </label>
    <label class="flex cursor-pointer items-center gap-2 pb-1.5 text-sm text-on-deep">
      <input type="checkbox" data-style="outline" class="h-4 w-4 accent-aqua" />
      {sb.outline}
    </label>
    <div class={field}>
      {sb.position}
      <div class="pos-seg" role="group" aria-label={sb.position}>
        <button type="button" data-pos="top" aria-label={sb.top} title={sb.top} aria-pressed="false">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 3h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="5" y="6" width="6" height="6" rx="1" fill="currentColor"/></svg>
        </button>
        <button type="button" data-pos="middle" aria-label={sb.middle} title={sb.middle} aria-pressed="false">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="5" y="5" width="6" height="6" rx="1" fill="currentColor"/></svg>
        </button>
        <button type="button" data-pos="bottom" aria-label={sb.bottom} title={sb.bottom} aria-pressed="false">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="5" y="4" width="6" height="6" rx="1" fill="currentColor"/></svg>
        </button>
        <button type="button" data-pos="custom" aria-label={sb.custom} title={sb.custom} aria-keyshortcuts="ArrowUp ArrowDown" aria-pressed="false">
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 3l4 10 1.4-3.6L12 8z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .preset-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    width: 4.25rem;
    height: 3.5rem;
    border-radius: 12px;
    border: 1px solid color-mix(in oklab, var(--color-on-deep-soft) 25%, transparent);
    background: var(--color-deep-soft);
    color: var(--color-on-deep);
    transition: border-color 0.15s, background 0.15s;
  }
  .preset-chip:hover { border-color: var(--color-on-deep-soft); }
  .preset-chip:focus-visible { outline: 2px solid var(--color-aqua); outline-offset: 1px; }
  .preset-chip.is-active {
    border-color: var(--color-aqua);
    background: color-mix(in oklab, var(--color-aqua) 12%, var(--color-deep-soft));
  }
  .preset-chip.is-active .font-display { color: var(--color-aqua); }

  /* Segmento de posición (arriba/centro/abajo/libre). */
  .pos-seg {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    border-radius: 10px;
    border: 1px solid color-mix(in oklab, var(--color-on-deep-soft) 25%, transparent);
    background: var(--color-deep);
  }
  .pos-seg button {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 7px;
    color: var(--color-on-deep-soft);
    transition: background 0.15s, color 0.15s;
  }
  .pos-seg button svg { width: 1rem; height: 1rem; }
  .pos-seg button:hover { color: var(--color-on-deep); background: color-mix(in oklab, var(--color-on-deep-soft) 12%, transparent); }
  .pos-seg button:focus-visible { outline: 2px solid var(--color-aqua); outline-offset: 1px; }
  .pos-seg button[aria-pressed="true"] { background: var(--color-aqua); color: var(--color-deep); }

  /* Pills de Animación / Personalizar. Borde aqua al activar. */
  .ctl-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--color-on-deep-soft) 30%, transparent);
    color: var(--color-on-deep);
    font-size: 0.875rem;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .ctl-pill:hover { border-color: var(--color-on-deep); }
  .ctl-pill:focus-visible { outline: 2px solid var(--color-aqua); outline-offset: 1px; }
  .ctl-pill[aria-expanded="true"],
  .ctl-pill[aria-pressed="true"] {
    border-color: var(--color-aqua);
    color: var(--color-aqua);
    background: color-mix(in oklab, var(--color-aqua) 10%, transparent);
  }
  .ctl-w {
    display: grid;
    place-items: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    border: 1.5px solid currentColor;
    font: 700 0.7rem/1 var(--font-sans);
  }
</style>
