---
import Footer from "@/components/Footer.astro";
import { ui } from "@/i18n/ui";
import { localePath, type Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const home = `${localePath[lang]}/`;
---

<header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
  <a href={home} class="group flex items-center gap-2.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink rounded-pill" aria-label="Subwave">
    <svg viewBox="0 0 64 64" class="h-9 w-9" aria-hidden="true">
      <rect width="64" height="64" rx="15" fill="#070B10" />
      <path d="M13 30 C20 20 27 20 31 30 C35 40 44 40 51 30" fill="none" stroke="#2DE0CE" stroke-width="5" stroke-linecap="round" />
      <path d="M13 41 C20 34 27 34 31 41 C35 48 44 48 51 41" fill="none" stroke="#15B5A6" stroke-width="3.5" stroke-linecap="round" />
    </svg>
    <span class="font-sans text-xl font-semibold tracking-tight text-ink">Subwave</span>
  </a>

  <nav class="flex items-center gap-1 text-sm sm:gap-2" aria-label={t.navLabel}>
    <a href="#how" class="hidden rounded-pill px-3 py-2 text-ink-soft transition hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink sm:inline-block">{t.nav.how}</a>
    <a href="#privacy" class="hidden rounded-pill px-3 py-2 text-ink-soft transition hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink sm:inline-block">{t.nav.privacy}</a>

    <span class="mx-1 hidden h-4 w-px bg-line sm:inline-block" aria-hidden="true"></span>

    <span class="flex items-center rounded-pill border border-line p-0.5 font-mono text-xs" role="group" aria-label={t.langLabel}>
      <a href="/" data-locale="en" aria-current={lang === "en" ? "true" : undefined}
         class={`rounded-pill px-2.5 py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink ${lang === "en" ? "bg-ink text-paper" : "text-ink-soft hover:text-ink"}`}>EN</a>
      <a href="/es/" data-locale="es" aria-current={lang === "es" ? "true" : undefined}
         class={`rounded-pill px-2.5 py-1 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink ${lang === "es" ? "bg-ink text-paper" : "text-ink-soft hover:text-ink"}`}>ES</a>
    </span>

    <a href="#app" data-action="start" class="ml-1 rounded-pill bg-ink px-4 py-2 font-medium text-paper transition hover:bg-aqua hover:text-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:ring-offset-2 focus-visible:ring-offset-paper">{t.nav.start}</a>
  </nav>
</header>

<main id="main-content" class="mx-auto max-w-6xl px-6">
  <!-- Hero -->
  <section class="grid items-center gap-12 py-12 sm:py-20 lg:grid-cols-2 lg:gap-16">
    <div>
      <p class="inline-flex items-center gap-2 rounded-pill border border-aqua-deep/40 bg-aqua-soft px-3 py-1 font-mono text-xs text-deep">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-aqua-deep" aria-hidden="true"></span>
        {t.hero.badge}
      </p>
      <h1 data-landing-heading tabindex="-1" class="mt-5 text-5xl leading-[1.05] text-ink focus:outline-none sm:text-6xl lg:text-7xl">
        {t.hero.titleLead} <em class="italic text-ink underline decoration-aqua-deep decoration-[3px] underline-offset-[8px]">{t.hero.titleEm}</em>
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">{t.hero.sub}</p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#app" data-action="start" class="rounded-pill bg-aqua px-6 py-3 font-medium text-deep shadow-soft transition hover:bg-aqua-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:ring-offset-2 focus-visible:ring-offset-paper">{t.hero.ctaPrimary}</a>
        <a href="#how" class="rounded-pill border border-line bg-paper-soft px-6 py-3 font-medium text-ink transition hover:border-ink-soft focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink">{t.hero.ctaSecondary}</a>
      </div>

      <p class="mt-6 font-mono text-xs tracking-wide text-ink-soft">{t.hero.formats}</p>
    </div>

    <!-- Brand moment: "agua profunda" card on paper, animated wave resolving into caption lines. -->
    <div class="rounded-card bg-deep p-6 shadow-soft sm:p-8">
      <svg viewBox="0 0 440 230" class="wave-art w-full" aria-hidden="true">
        <path class="wave-main" d="M20 70 C55 32 95 32 120 70 C145 108 185 108 220 70 C255 32 295 32 320 70 C345 108 385 108 420 70"
              fill="none" stroke="#2DE0CE" stroke-width="5" stroke-linecap="round" />
        <path class="wave-sub" d="M20 92 C55 64 95 64 120 92 C145 120 185 120 220 92 C255 64 295 64 320 92 C345 120 385 120 420 92"
              fill="none" stroke="#15B5A6" stroke-width="3.5" stroke-linecap="round" />
        <path class="wave-crest" d="M20 70 C55 32 95 32 120 70 C145 108 185 108 220 70 C255 32 295 32 320 70 C345 108 385 108 420 70"
              fill="none" stroke="#EEF2F0" stroke-width="5" stroke-linecap="round" />

        <g class="caps">
          <rect class="cap" x="20" y="150" width="300" height="14" rx="7" fill="#1A2A33" />
          <rect class="cap" x="20" y="176" width="380" height="14" rx="7" fill="#15B5A6" opacity="0.55" />
          <rect class="cap" x="20" y="202" width="220" height="14" rx="7" fill="#1A2A33" />
        </g>
      </svg>
      <p class="mt-4 text-center font-mono text-xs text-on-deep-soft">{t.hero.caption}</p>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="scroll-mt-8 border-t border-line py-16 sm:py-20">
    <h2 class="text-3xl text-ink sm:text-4xl">{t.steps.title}</h2>
    <p class="mt-3 max-w-2xl text-ink-soft">{t.steps.lead}</p>

    <ol class="mt-10 grid gap-6 sm:grid-cols-3">
      {t.steps.items.map((step, i) => (
        <li class="rounded-card border border-line bg-paper-soft p-6 shadow-soft">
          <span class="flex h-9 w-9 items-center justify-center rounded-pill bg-aqua font-mono text-sm font-medium text-deep">{i + 1}</span>
          <h3 class="mt-4 text-xl text-ink">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{step.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- Privacy -->
  <section id="privacy" class="scroll-mt-8 pb-20">
    <div class="overflow-hidden rounded-card bg-deep p-8 text-on-deep shadow-soft sm:p-12">
      <h2 class="text-3xl text-on-deep sm:text-4xl">{t.privacy.title}</h2>
      <p class="mt-4 max-w-2xl leading-relaxed text-on-deep-soft">{t.privacy.body}</p>
      <ul class="mt-8 flex flex-wrap gap-3">
        {t.privacy.points.map((point) => (
          <li class="inline-flex items-center gap-2 rounded-pill border border-aqua-deep/40 bg-deep-soft px-4 py-2 text-sm text-on-deep">
            <svg viewBox="0 0 16 16" class="h-3.5 w-3.5 text-aqua" aria-hidden="true"><path d="M3 8.5 6.5 12 13 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
            {point}
          </li>
        ))}
      </ul>
    </div>
  </section>
</main>

<Footer lang={lang} />

<style>
  /* Sub-onda con bob suave. */
  .wave-sub { transform-box: view-box; transform-origin: center; animation: bob 4s ease-in-out infinite; }

  /* La cresta recorre la onda de izquierda a derecha (motivo "transcribir"). */
  .wave-crest {
    stroke-dasharray: 26 620;
    stroke-dashoffset: 646;
    opacity: 0.9;
    animation: crest 3.6s linear infinite;
  }

  /* Líneas de subtítulo: brillo sutil escalonado. Base = visibles (sin motion siguen así). */
  .cap { animation: cap 3.6s ease-in-out infinite; }
  .cap:nth-child(2) { animation-delay: 0.5s; }
  .cap:nth-child(3) { animation-delay: 1s; }

  @keyframes crest { to { stroke-dashoffset: 0; } }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(4px); } }
  @keyframes cap { 0%, 100% { opacity: 0.55; } 50% { opacity: 1; } }
</style>
