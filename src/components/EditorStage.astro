---
import EditorSidebar from "@/components/EditorSidebar.astro";
import SubtitleStyleBar from "@/components/SubtitleStyleBar.astro";
import Timeline from "@/components/Timeline.astro";
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const e = ui[lang].app.editor;
const iconBtn =
  "rounded-pill border border-on-deep-soft/30 px-4 py-2.5 text-sm font-medium text-on-deep transition hover:border-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua disabled:cursor-not-allowed disabled:opacity-40";
---

<section data-stage="editor" hidden aria-labelledby="editor-h" class="mx-auto max-w-6xl px-6 py-10 sm:py-12">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 id="editor-h" data-stage-heading tabindex="-1" class="text-3xl text-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua sm:text-4xl">{e.title}</h2>
      <p class="mt-2 text-on-deep-soft">{e.lead}</p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" data-action="back" class={iconBtn}>{ui[lang].app.back}</button>
      <button type="button" data-editor="undo" disabled class={iconBtn}>{e.undo}</button>
      <button type="button" data-editor="redo" disabled class={iconBtn}>{e.redo}</button>
      <button type="button" data-action="export" disabled class="rounded-pill bg-aqua px-5 py-2.5 font-medium text-deep transition hover:bg-aqua-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua focus-visible:ring-offset-2 focus-visible:ring-offset-deep disabled:cursor-not-allowed disabled:opacity-40">{e.export}</button>
    </div>
  </div>

  <div class="mt-8">
    <SubtitleStyleBar lang={lang} />
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-[22rem_1fr]">
    <EditorSidebar lang={lang} />

    <div class="space-y-6">
      <!-- Preview con overlay del subtítulo activo -->
      <div data-editor="preview" class="relative grid aspect-video place-items-center overflow-hidden rounded-card border border-on-deep-soft/15 bg-deep">
        <span class="font-mono text-xs uppercase tracking-wide text-on-deep-soft">{e.preview}</span>
        <video data-editor="video" hidden playsinline controls class="absolute inset-0 h-full w-full bg-black object-contain"></video>
        <div data-editor="overlay" aria-hidden="true" class="pointer-events-none absolute inset-0 flex justify-center p-5" style="align-items:flex-end">
          <span data-editor="bubble" class="max-w-[92%] rounded text-center leading-tight"></span>
        </div>
      </div>
      <audio data-editor="audio" hidden controls class="w-full"></audio>

      <Timeline lang={lang} />
    </div>
  </div>
</section>
