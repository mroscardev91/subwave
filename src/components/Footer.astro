---
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 px-6 py-10 sm:flex-row sm:items-center">
    <div class="flex items-center gap-3">
      <svg viewBox="0 0 64 64" class="h-7 w-7" aria-hidden="true">
        <rect width="64" height="64" rx="15" fill="#070B10" />
        <path d="M13 30 C20 20 27 20 31 30 C35 40 44 40 51 30" fill="none" stroke="#2DE0CE" stroke-width="5" stroke-linecap="round" />
        <path d="M13 41 C20 34 27 34 31 41 C35 48 44 48 51 41" fill="none" stroke="#15B5A6" stroke-width="3.5" stroke-linecap="round" />
      </svg>
      <div>
        <p class="font-display text-lg leading-none text-ink">{t.footer.tagline}</p>
        <p class="mt-1 font-mono text-xs text-ink-soft">{t.footer.note}</p>
      </div>
    </div>

    <p class="font-mono text-xs text-ink-soft">© {year} Subwave · {t.footer.rights}</p>
  </div>
</footer>
