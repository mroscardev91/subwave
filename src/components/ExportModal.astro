---
import { ui } from "@/i18n/ui";
import type { Lang } from "@/i18n/locales";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const x = ui[lang].app.exportModal;
const option =
  "w-full rounded-card border border-on-deep-soft/20 bg-deep p-4 text-left transition hover:border-aqua focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua disabled:cursor-not-allowed disabled:opacity-40";
---

<div data-export="overlay" hidden role="dialog" aria-modal="true" aria-labelledby="export-title" class="fixed inset-0 z-50 grid place-items-center bg-deep/85 p-4 backdrop-blur">
  <div class="w-full max-w-md rounded-card border border-on-deep-soft/15 bg-deep-soft p-6 shadow-soft">
    <div class="flex items-center justify-between">
      <h2 id="export-title" class="text-2xl text-on-deep">{x.title}</h2>
      <button type="button" data-export="close" aria-label={x.close} class="inline-flex h-8 w-8 items-center justify-center rounded-pill text-on-deep-soft transition hover:bg-on-deep-soft/15 hover:text-on-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua">
        <svg viewBox="0 0 16 16" class="h-4 w-4" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>
      </button>
    </div>

    <div class="mt-5 space-y-3">
      <button type="button" data-export="srt" class={option}>
        <span class="flex items-center gap-2 font-medium text-on-deep">
          <svg viewBox="0 0 16 16" class="h-4 w-4 text-aqua" aria-hidden="true"><path d="M8 2v8m0 0 3-3m-3 3L5 7M3 13h10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          {x.srt}
        </span>
        <span class="mt-1 block text-sm text-on-deep-soft">{x.srtHint}</span>
      </button>

      <button type="button" data-export="video" class={option}>
        <span class="flex items-center gap-2 font-medium text-on-deep">
          <svg viewBox="0 0 16 16" class="h-4 w-4 text-aqua" aria-hidden="true"><path d="M2 4h12v8H2z M6 6l4 2-4 2z" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" /></svg>
          {x.video}
        </span>
        <span class="mt-1 block text-sm text-on-deep-soft">{x.videoHint}</span>
        <span class="mt-1 block font-mono text-xs text-on-deep-soft">{x.webmNote}</span>
      </button>
    </div>

    <div data-export="progress" hidden tabindex="-1" class="mt-5 focus-visible:outline-none">
      <div class="flex items-center justify-between text-sm text-on-deep-soft">
        <span data-export="status" id="export-status" aria-live="polite"></span>
        <span data-export="pct" class="font-mono"></span>
      </div>
      <div role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-labelledby="export-status" class="mt-2 h-2 overflow-hidden rounded-pill bg-deep">
        <div data-export="bar" class="h-full rounded-pill bg-aqua transition-[width] duration-200" style="width:0%"></div>
      </div>
    </div>

    <p data-export="error" hidden role="alert" class="mt-5 rounded-card border border-alert/40 bg-alert/10 px-4 py-3 text-sm text-alert"></p>
  </div>
</div>
